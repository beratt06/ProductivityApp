@page
@model RegisterModel
@{
    ViewData["Title"] = "Kayıt";
}

<section class="login-panel">
    <div class="auth-card">
        <div class="auth-mark">P</div>
        <h1>Hesap Oluştur</h1>
        <p>Görevlerini, alışkanlıklarını ve odak seanslarını sakla.</p>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post" class="stack-form">
            <label asp-for="Input.DisplayName">Ad soyad</label>
            <input asp-for="Input.DisplayName" autocomplete="name" />
            <span asp-validation-for="Input.DisplayName"></span>

            <label asp-for="Input.UserName">Kullanıcı adı</label>
            <input asp-for="Input.UserName" autocomplete="username" />
            <span asp-validation-for="Input.UserName"></span>

            <label asp-for="Input.Password">Şifre</label>
            <input asp-for="Input.Password" type="password" autocomplete="new-password" />
            <span asp-validation-for="Input.Password"></span>

            <button class="primary-action" type="submit">Kaydol</button>
        </form>

        <div class="auth-footer">
            <span>Hesabın var mı?</span>
            <a asp-page="/Login">Giriş yap</a>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
